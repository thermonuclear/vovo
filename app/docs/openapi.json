{
    "openapi": "3.0.3",
    "info": {
        "title": "Vovo Product Catalog API",
        "version": "1.0.0",
        "description": "REST API для каталога товаров с поиском, фильтрами и пагинацией",
        "contact": {
            "name": "Vovo API Support"
        }
    },
    "servers": [
        {
            "url": "http://localhost:8080/api",
            "description": "Local development"
        }
    ],
    "tags": [
        {
            "name": "Products",
            "description": "Операции с товарами"
        }
    ],
    "paths": {
        "/products": {
            "get": {
                "summary": "Получить список товаров",
                "description": "Возвращает пагинированный список товаров с возможностью фильтрации и сортировки",
                "tags": ["Products"],
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Поиск по подстроке в названии товара (FULLTEXT / LIKE)",
                        "required": false,
                        "schema": { "type": "string", "maxLength": 255 },
                        "example": "смартфон"
                    },
                    {
                        "name": "price_from",
                        "in": "query",
                        "description": "Минимальная цена",
                        "required": false,
                        "schema": { "type": "number", "minimum": 0 },
                        "example": 100
                    },
                    {
                        "name": "price_to",
                        "in": "query",
                        "description": "Максимальная цена",
                        "required": false,
                        "schema": { "type": "number", "minimum": 0 },
                        "example": 500
                    },
                    {
                        "name": "category_id",
                        "in": "query",
                        "description": "Фильтр по категории",
                        "required": false,
                        "schema": { "type": "integer" },
                        "example": 1
                    },
                    {
                        "name": "in_stock",
                        "in": "query",
                        "description": "Только товары в наличии",
                        "required": false,
                        "schema": { "type": "boolean" },
                        "example": true
                    },
                    {
                        "name": "rating_from",
                        "in": "query",
                        "description": "Минимальный рейтинг (0–5)",
                        "required": false,
                        "schema": { "type": "number", "minimum": 0, "maximum": 5 },
                        "example": 4
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "description": "Сортировка результатов",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": ["price_asc", "price_desc", "rating_desc", "newest"],
                            "default": "newest"
                        },
                        "example": "price_asc"
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Количество товаров на странице (1–100)",
                        "required": false,
                        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 15 },
                        "example": 10
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Номер страницы",
                        "required": false,
                        "schema": { "type": "integer", "minimum": 1, "default": 1 },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успешный ответ с пагинированным списком товаров",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/PaginatedProductResponse" },
                                "example": {
                                    "data": [
                                        {
                                            "id": 1,
                                            "name": "Смартфон Galaxy Pro",
                                            "price": "299.99",
                                            "category": {
                                                "id": 1,
                                                "name": "Электроника",
                                                "slug": "elektronika"
                                            },
                                            "in_stock": true,
                                            "rating": 4.5,
                                            "created_at": "2024-01-01T00:00:00Z",
                                            "updated_at": "2024-01-01T00:00:00Z"
                                        }
                                    ],
                                    "meta": {
                                        "current_page": 1,
                                        "last_page": 5,
                                        "per_page": 10,
                                        "total": 50
                                    },
                                    "links": {
                                        "first": "http://localhost:8080/api/products?page=1",
                                        "last": "http://localhost:8080/api/products?page=5",
                                        "next": "http://localhost:8080/api/products?page=2",
                                        "prev": null
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Ошибка валидации параметров запроса",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/ValidationError" },
                                "example": {
                                    "message": "The sort field must be one of: price_asc, price_desc, rating_desc, newest.",
                                    "errors": {
                                        "sort": ["The sort field must be one of: price_asc, price_desc, rating_desc, newest."]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Category": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "description": "Уникальный идентификатор категории" },
                    "name": { "type": "string", "description": "Название категории" },
                    "slug": { "type": "string", "description": "URL-идентификатор категории" }
                }
            },
            "Product": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "description": "Уникальный идентификатор товара" },
                    "name": { "type": "string", "description": "Название товара" },
                    "price": { "type": "string", "description": "Цена товара (decimal)" },
                    "category": { "$ref": "#/components/schemas/Category" },
                    "in_stock": { "type": "boolean", "description": "Наличие на складе" },
                    "rating": { "type": "number", "description": "Рейтинг товара (0–5)", "minimum": 0, "maximum": 5 },
                    "created_at": { "type": "string", "format": "date-time", "description": "Дата создания (ISO 8601)" },
                    "updated_at": { "type": "string", "format": "date-time", "description": "Дата обновления (ISO 8601)" }
                }
            },
            "PaginatedProductResponse": {
                "type": "object",
                "properties": {
                    "data": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/Product" }
                    },
                    "meta": {
                        "type": "object",
                        "properties": {
                            "current_page": { "type": "integer" },
                            "last_page": { "type": "integer" },
                            "per_page": { "type": "integer" },
                            "total": { "type": "integer" }
                        }
                    },
                    "links": {
                        "type": "object",
                        "properties": {
                            "first": { "type": "string", "nullable": true },
                            "last": { "type": "string", "nullable": true },
                            "next": { "type": "string", "nullable": true },
                            "prev": { "type": "string", "nullable": true }
                        }
                    }
                }
            },
            "ValidationError": {
                "type": "object",
                "properties": {
                    "message": { "type": "string", "description": "Общее сообщение об ошибке" },
                    "errors": {
                        "type": "object",
                        "description": "Детали ошибок по полям",
                        "additionalProperties": {
                            "type": "array",
                            "items": { "type": "string" }
                        }
                    }
                }
            }
        }
    }
}
