# Application (используется Docker для container_name)
APP_NAME=vovo
APP_ENV=local

# Ports (host mapping)
NGINX_PORT=8080
MYSQL_PORT=3306
PHPMYADMIN_PORT=8081
REDIS_PORT=6379

# Database credentials (для Docker MySQL контейнера)
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=vovo
DB_USERNAME=vovo
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Redis (для Docker Redis контейнера)
REDIS_HOST=redis

# Queue
REDIS_QUEUE_DB=2
REDIS_QUEUE_RETRY_AFTER=120

# Export service URL
EXPORT_ORDER_URL=https://httpbin.org/post
